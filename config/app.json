{
    "app": {
        "display_name": "ChatClient",
        "login_window_title": "chatClient 登录",
        "chat_window_title": "chatClient 聊天"
    },
    "services": {
        "http": {
            "base_url": "http://127.0.0.1:8848",
            "register_path": "/api/v1/auth/register",
            "login_path": "/api/v1/auth/login",
            "logout_path": "/api/v1/auth/logout",
            "avatar_temp_upload_path": "/api/v1/users/avatar/temp",
            "file_upload_path": "/api/v1/files/upload",
            "file_download_path_template": "/api/v1/files/{attachment_id}",
            "user_avatar_path_template": "/api/v1/users/{user_id}/avatar",
            "user_search_path": "/api/v1/users/search",
            "friend_list_path": "/api/v1/friends",
            "friend_send_request_path": "/api/v1/friends/requests",
            "friend_outgoing_requests_path": "/api/v1/friends/requests/outgoing",
            "friend_incoming_requests_path": "/api/v1/friends/requests/incoming",
            "friend_accept_request_path_template": "/api/v1/friends/requests/{request_id}/accept",
            "friend_reject_request_path_template": "/api/v1/friends/requests/{request_id}/reject",
            "conversation_private_path": "/api/v1/conversations/private",
            "conversation_list_path": "/api/v1/conversations",
            "conversation_detail_path_template": "/api/v1/conversations/{conversation_id}",
            "conversation_messages_path_template": "/api/v1/conversations/{conversation_id}/messages",
            "conversation_send_text_path_template": "/api/v1/conversations/{conversation_id}/messages/text"
        },
        "ws": {
            "url": "ws://127.0.0.1:8848/ws"
        }
    },
    "log": {
        "app_name": "chatClient",
        "minimum_level": "INFO",
        "enable_console": true,
        "enable_file": true,
        "display_local_time": true,
        "directory": "../logs",
        "file_name": "chatclient.log"
    }
}
